{
  "name": "wait-for-vercel-preview",
  "version": "1.3.1",
  "description": "Wait for a Vercel preview deployment to be ready",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrickedqvist/wait-for-vercel-preview.git"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run lint && npm run prepare && npm run test"
  },
  "keywords": [
    "Vercel",
    "Deployment",
    "Preview",
    "Actions"
  ],
  "author": "Patrick Edqvist <patrick.edqvist@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/patrickedqvist/wait-for-vercel-preview/issues"
  },
  "homepage": "https://github.com/patrickedqvist/wait-for-vercel-preview#readme",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^5.1.1",
    "@vercel/ncc": "^0.38.0",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.15",
    "@types/jest": "^29.5.4",
    "deepmerge": "^4.3.1",
    "eslint": "^8.49.0",
    "jest": "^29.6.4",
    "msw": "^1.3.0"
  }
}
